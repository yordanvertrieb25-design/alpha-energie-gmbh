// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactRequest {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model PartnerApplication {
  id         Int      @id @default(autoincrement())
  fullName   String
  email      String
  phone      String
  experience String
  createdAt  DateTime @default(now())
}

model Appointment {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  date      String   
  time      String   
  createdAt DateTime @default(now())
}

model Campaign {
  id          Int              @id @default(autoincrement())
  name        String
  industry    String
  companySize String
  createdAt   DateTime         @default(now())
  contacts    ScrapedContact[]
}

model ScrapedContact {
  id         Int        @id @default(autoincrement())
  campaignId Int
  campaign   Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name       String
  phone      String?
  website    String?
  email      String?
  status     String     @default("PENDING") // PENDING, SENT, FAILED
  createdAt  DateTime   @default(now())
  emailLogs  EmailLog[]
}

model EmailLog {
  id               Int            @id @default(autoincrement())
  scrapedContactId Int
  scrapedContact   ScrapedContact @relation(fields: [scrapedContactId], references: [id], onDelete: Cascade)
  sentAt           DateTime       @default(now())
  status           String         // SUCCESS, FAILED
  errorMessage     String?
  subject          String
  body             String
}
